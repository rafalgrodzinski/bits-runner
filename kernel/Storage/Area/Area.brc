@module Storage

@export Area blob
    device proto<Device>
    partitionNumber u32
    firstSector u32
    sectorsCount u32

    init fun: device proto<Device>, partitionNumber u32, firstSector u32, sectorsCount u32
        it.device <- device
        it.partitionNumber <- partitionNumber
        it.sectorsCount <- sectorsCount
    ;

    readSectors fun: sector u32, count u32, targetAddress a -> u32
        ret it.device.readSectors(it.firstSector + sector, count, targetAddress)
    ;
;