@module Storage

@export StorageDevice blob
    biosDriveNum u32
    sectorsCount u32
    readSectors ptr<fun: ptr<blob<StorageDevice>>, u32, u32, ptr<data<u8>> -> u32>
;

@export Device proto
    biosDriveNumber u32
    sectorsCount u32

    readSectors fun: sector u32, count u32, targetAddress a -> u32
;