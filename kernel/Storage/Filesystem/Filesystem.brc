@module Storage

@import B

@export Filesystem proto
    kind u32
    area blob<Area>

    getRootEntry fun -> blob<Entry>
    getChildEntries fun: parentEntry blob<Entry> -> data<blob<Entry>, 32>
    getEntryForPath fun: path blob<@B::String> -> blob<Entry>
    readEntry fun: entry blob<Entry>, targetAddress a -> u32
;