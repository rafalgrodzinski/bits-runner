@module Storage

@import B

@export StorageFsEntry blob
    kind u32
    name data<u8, 16>
    entrySize u32

    // FAT specific
    fatCluster u32
;

@export Filesystem proto
    kind u32
    area blob<Area>

    getRootEntry fun -> blob<StorageFsEntry>
    getChildEntries fun: parentEntry blob<StorageFsEntry> -> data<blob<StorageFsEntry>, 32>
    getEntryForPath fun: path blob<@B::String> -> blob<StorageFsEntry>
    readEntry fun: entry blob<StorageFsEntry>, targetAddress a -> u32
;