        ret 0
    ;

    readEntry fun: pEntry ptr<blob<Entry>>, startByte u32, bytesCount u32, targetAddress a -> u32
        cluster u32 <- pEntry.val.aMetadata.ptr<blob<Entry::Metadata::Fat>>.val.cluster
        bytesPerCluster u32 <- it.fatSectorsPerCluster * it.fatBytesPerSector

        bytesCopied u32
        // Make sure we don't copy more than the size of the file
        if startByte >= pEntry.val.fileSize: ret 0
        bytesCount <- if startByte + bytesCount < pEntry.val.fileSize: bytesCount else: pEntry.val.fileSize - startByte

        // Start at the correct cluster
        startClusterIndex u32 <- startByte / bytesPerCluster
        rep i u32, i < startClusterIndex, i <- i + 1
            cluster <- it.nextCluster(cluster)
        ;
        firstClusterBytesOffset u32 <- startByte % bytesPerCluster
        firstClusterBytesCount u32 <- bytesPerCluster - firstClusterBytesOffset
        lastClusterBytesCount u32 <- (bytesCount - firstClusterBytesCount) % bytesPerCluster

        rep bytesCopied < bytesCount
            sector u32 <- it.sectorForCluster(cluster)
            cluster <- it.nextCluster(cluster)

            // Handle copying from the offset of the first cluster
            if bytesCopied = 0 and firstClusterBytesOffset > 0
                aBuffer a <- @BSys::memAlloc(bytesPerCluster)
                it.area.readSectors(sector, it.fatSectorsPerCluster, aBuffer)
                // copy just the required bytes
                rep i u32, i < firstClusterBytesCount, i <- i + 1
                    targetAddress.ptr<data<u8>>.val[i] <- aBuffer.ptr<data<u8>>.val[firstClusterBytesOffset + i]
                ;
                @BSys::memFree(aBuffer)
                bytesCopied <- firstClusterBytesCount
            // Handle copying remainder of less than a cluster size
            else if bytesCount - bytesCopied < bytesPerCluster
                aBuffer a <- @BSys::memAlloc(bytesPerCluster)
                it.area.readSectors(sector, it.fatSectorsPerCluster, aBuffer)
                // copy just the required bytes
                rep i u32, i < lastClusterBytesCount, i <- i + 1
                    targetAddress.ptr<data<u8>>.val[bytesCopied + i] <- aBuffer.ptr<data<u8>>.val[i]
                ;
                @BSys::memFree(aBuffer)
                bytesCopied <- bytesCopied + lastClusterBytesCount
            // Copy a full cluster
            else
                it.area.readSectors(sector, it.fatSectorsPerCluster, targetAddress + bytesCopied)
                bytesCopied <- bytesCopied + bytesPerCluster
            ;
        ;

        ret bytesCopied
    ;

    deleteEntry fun: pEntry ptr<blob<Entry>>
        pMetadata ptr<blob<Entry::Metadata::Fat>> <- pEntry.val.aMetadata.ptr<blob<Entry::Metadata::Fat>>
        dirEntrySector u32
        dirEntrySectorOffset u32 <- pMetadata.val.dirEntryOffset % it.fatBytesPerSector

        // Remove clusters chain
        cluster u32 <- pMetadata.val.cluster
        terminalCluster u32 <- if it.kind = FS_KIND_FAT12: FAT12_EOF else: FAT16_EOF
        rep cluster < terminalCluster
            currentCluster u32 <- cluster
            cluster <- it.nextCluster(cluster)
            if it.kind = FS_KIND_FAT12
                // we multiply by 1.5 because FAT12 uses 1.5 bytes cluster entry
                pCurrentCluster ptr<u16> <- {it.aFat + currentCluster * 3 / 2}

                // zero cluster depending on wethere cluster is odd or even
                if currentCluster &? 0x01
                    pCurrentCluster.val <- pCurrentCluster.val & 0x000f
                else
                    pCurrentCluster.val <- pCurrentCluster.val & 0xf000
                ;
            else if it.kind = FS_KIND_FAT16
                //{it.aFat + cluster * 2}.ptr<u16>.val <- 0
                pCurrentCluster ptr<u16> <- {it.aFat + currentCluster * 2}.ptr<u16>
                pCurrentCluster.val <- 0
            ;
        ;

        // Write back updated fat tables
        rep i u32, i < it.fatsCount, i <- i + 1
            targetSector u32 <- it.fatFirstDataSector + it.sectorsPerFat * i
            it.area.writeSectors(targetSector, it.sectorsPerFat, it.aFat)
        ;

        // Is in root directory?
        if pMetadata.val.dirCluster = 0
            dirEntrySector <- it.fatRootDirFirstSector + pMetadata.val.dirEntryOffset / it.fatBytesPerSector
        // Is in sub directory
        else
            bytesPerCluster u32 <- it.fatBytesPerSector * it.fatSectorsPerCluster
            // figure out cluster for the entry
            entryClusterIndex u32 <- pMetadata.val.dirEntryOffset / bytesPerCluster
            dirEntryCluster u32 <- pMetadata.val.dirCluster
            rep i u32, i < entryClusterIndex, i <- i + 1: dirEntryCluster <- it.nextCluster(dirEntryCluster)
            // and then the sector
            dirEntrySector <- it.sectorForCluster(dirEntryCluster) + ((pMetadata.val.dirEntryOffset % bytesPerCluster) / it.fatBytesPerSector)
        ;

        aBuffer a <- @BSys::memAlloc(it.fatBytesPerSector)
        it.area.readSectors(dirEntrySector, 1, aBuffer)
        //{aBuffer + dirEntrySectorOffset}.ptr<u8>.val <- 0xe5 
        pDirEntry ptr<data<u8>> <- {aBuffer + dirEntrySectorOffset}.ptr<data<u8>>
        pDirEntry.val[0] <- 0xe5
        written u32 <- it.area.writeSectors(dirEntrySector, 1, aBuffer)
    ;

    nextCluster fun: cluster u32 -> u32
        if it.kind = FS_KIND_FAT12
            // Check if we're aleady at the last cluster
            if cluster >= FAT12_EOF: ret cluster

            // we multiply by 1.5 because FAT12 uses 1.5 bytes cluster entry
            pCluster ptr<u16> <- {it.aFat + cluster * 3 / 2}

            // calculate next cluster depending on wethere cluster is odd or even
            if cluster &? 0x01
                cluster <- (pCluster.val & 0xfff0) >> 4
            else
                cluster <- pCluster.val & 0x0fff
            ;
        else if it.kind = FS_KIND_FAT16
            // Check if we're aleady at the last cluster
            if cluster >= FAT16_EOF: ret cluster

            pCluster ptr<u16> <- {it.aFat + cluster * 2}
            cluster <- pCluster.val
        ;

        ret cluster
    ;

    sectorForCluster fun: cluster u32 -> u32
        ret (cluster - 2) * it.fatSectorsPerCluster + it.fatFirstDataSector
    ;

    entryForFatEntry fun: aFatEntry a -> ptr<blob<Entry>>
        pEntry ptr<blob<Entry>>

        pFatEntry ptr<data<u8>> <- aFatEntry.ptr<data<u8>>
        isEmpty bool <- pFatEntry.val[0] = 0x00
        isDeleted bool <- pFatEntry.val[0] = 0xe5
        attribute u8 <- pFatEntry.val[FAT_ENTRY_ATTRIB_OFFSET]
        isLongFileName bool <- attribute &? FAT_ATTRIB_LONG_FILE_NAME
        isVolumeId bool <- attribute &? FAT_ATTRIB_VOLUME_ID and not isLongFileName
        isHidden bool <- attribute &? FAT_ATTRIB_HIDDEN
        isNavigationDirectory bool <- (pFatEntry.val[0] = '.' and pFatEntry.val[1] = ' ') or (pFatEntry.val[0] = '.' and pFatEntry.val[1] = '.' and pFatEntry.val[2] = ' ') 
        isDirectory bool <- attribute &? FAT_ATTRIB_DIR and not isNavigationDirectory
        isFile bool <- not isLongFileName and not isVolumeId and not isNavigationDirectory and not isDirectory and not isEmpty and not isDeleted

        if isFile or isDirectory
            pEntry <- @BSys::memAlloc(blob<Entry>.size).ptr<blob<Entry>>

            pEntry.val.kind <- if isFile: Entry::KIND_FILE else: Entry::KIND_DIRECTORY
            pEntry.val.fileSize <- (aFatEntry + FAT_ENTRY_SIZE_OFFSET).ptr<u32>.val

            // name
            name data<u8, 13> // 8 + '.' + 3 + \0

            targetIndex u32
            sourceIndex u32
            // file name
            rep sourceIndex < 8, sourceIndex <- sourceIndex + 1
                if pFatEntry.val[sourceIndex] != ' '
                    name[targetIndex] <- pFatEntry.val[sourceIndex]
                    targetIndex <- targetIndex + 1
                ;
            ;
            // dot
            if isFile
                name[targetIndex] <- '.'
                targetIndex <- targetIndex + 1
            ;
            // extension
            rep sourceIndex < 11, sourceIndex <- sourceIndex + 1
                if pFatEntry.val[sourceIndex] != ' '
                    name[targetIndex] <- pFatEntry.val[sourceIndex]
                    targetIndex <- targetIndex + 1
                ;
            ;
            name[targetIndex] <- 0

            pEntry.val.name <- @B::String(name)

            // metadata
            pEntry.val.aMetadata <- @BSys::memAlloc(blob<Entry::Metadata::Fat>.size)
            pEntry.val.aMetadata.ptr<blob<Entry::Metadata::Fat>>.val.cluster <- (aFatEntry + FAT_ENTRY_CLUSTER_OFFSET).ptr<u16>.val
        else if not isEmpty
            pEntry <- @BSys::memAlloc(blob<Entry>.size).ptr<blob<Entry>>
            pEntry.val.kind <- Entry::KIND_OTHER
            pEntry.val.aMetadata <- 0
        ;

        ret pEntry
    ;
;