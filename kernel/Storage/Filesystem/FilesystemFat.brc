@module Storage

@import BSys
@import Term

// Predefined
FAT_BYTES_PER_ENTRY u32 <- 0x20
FAT12_EOF u32 <- 0x0ff8
FAT16_EOF u32 <- 0xfff8

FS_KIND_FAT12 u32 <- 12
FS_KIND_FAT16 u32 <- 16

STORAGE_FS_ENTRY_KIND_FILE u32 <- 'f'
STORAGE_FS_ENTRY_KIND_DIR u32 <- 'd'

// FAT header offsets
FAT_BYTES_PER_SECTOR_OFFSET u32 <- 0x0b // 2 bytes
FAT_SECTORS_PER_CLUSTER_OFFSET u32 <- 0x0d // 1 byte
FAT_RESERVED_SECTORS_COUNT_OFFSET u32 <- 0x0e // 1 byte
FAT_FATS_COUNT_OFFSET u32 <- 0x10 // 1 byte
FAT_ROOT_DIR_ENTRIES_COUNT_OFFSET u32 <- 0x11 // 2 bytes
FAT_SECTORS_PER_FAT_OFFSET u32 <- 0x16 // 2 bytes
FAT_FS_ID_OFFSET u32 <- 0x36 // 8 bytes

// FAT Entry
FAT_ENTRY_ATTRIB_OFFSET u32 <- 0x0b // 1 byte
FAT_ENTRY_CLUSTER_OFFSET u32 <- 0x1a // 2 bytes
FAT_ENTRY_SIZE_OFFSET u32 <- 0x1c // 4 bytes

FAT_ATTRIB_HIDDEN u8 <- 0x02
FAT_ATTRIB_VOLUME_ID u8 <- 0x08
FAT_ATTRIB_LONG_FILE_NAME u8 <- 0x0f
FAT_ATTRIB_DIR u8 <- 0x10

FAT_FILE_FREE u8 <- 0xe5

@export FilesystemFat blob: Filesystem
    kind u32
    area blob<Area>

    // FAT specific
    name data<u8, 16>
    aFat a
    fatBytesPerSector u32
    fatRootDirEntriesCount u32
    fatSectorsPerCluster u32
    fatFirstDataSector u32
    fatRootDirFirstSector u32
    fatRootDirSectorsCount u32
    fatFirstSector u32
    sectorsPerFat u32
    fatsCount u32

    init fun: area blob<Area>
        it.area <- area

        // Init FAT
        aFatBuffer a <- @BSys::memAlloc(512)
        it.area.readSectors(0, 1, aFatBuffer)

        pInfo ptr<u32>

        // read values
        pInfo <- {aFatBuffer + FAT_BYTES_PER_SECTOR_OFFSET}
        bytesPerSector u32 <- pInfo.val & 0xffff
        it.fatBytesPerSector <- bytesPerSector

        pInfo <- {aFatBuffer + FAT_SECTORS_PER_CLUSTER_OFFSET}
        sectorsPerCluster u32 <- pInfo.val & 0xff
        it.fatSectorsPerCluster <- sectorsPerCluster

        pInfo <- {aFatBuffer + FAT_RESERVED_SECTORS_COUNT_OFFSET}
        reservedSectorsCount u32 <- pInfo.val & 0xff

        pInfo <- {aFatBuffer + FAT_FATS_COUNT_OFFSET}
        it.fatsCount <- pInfo.val & 0xff

        pInfo <- {aFatBuffer + FAT_ROOT_DIR_ENTRIES_COUNT_OFFSET}
        rootDirEntriesCount u32 <- pInfo.val & 0xffff
        it.fatRootDirEntriesCount <- rootDirEntriesCount

        pInfo <- {aFatBuffer + FAT_SECTORS_PER_FAT_OFFSET}
        it.sectorsPerFat <- pInfo.val & 0xffff

        // calculated values
        it.fatFirstSector <- reservedSectorsCount

        it.fatRootDirFirstSector <- it.fatFirstSector + it.sectorsPerFat * it.fatsCount

        it.fatRootDirSectorsCount <- (rootDirEntriesCount * FAT_BYTES_PER_ENTRY) / bytesPerSector

        it.fatFirstDataSector <- it.fatRootDirFirstSector + it.fatRootDirSectorsCount

        // FAT type
        pInfo <- {aFatBuffer + FAT_FS_ID_OFFSET + 4}
        if pInfo.val & 0xff = '2': it.kind <- FS_KIND_FAT12
        else if pInfo.val & 0xff = '6': it.kind <- FS_KIND_FAT16

        // load fat
        it.aFat <- @BSys::memAlloc(it.sectorsPerFat * bytesPerSector)
        it.area.readSectors(it.fatFirstSector, it.sectorsPerFat, it.aFat)
    ;

    getRootEntry fun -> ptr<blob<Entry>>
        pEntry ptr<blob<Entry>> <- @BSys::memAlloc(blob<Entry>.size).ptr<blob<Entry>>

        pEntry.val.kind <- STORAGE_FS_ENTRY_KIND_DIR
        pEntry.val.name <- @B::String("/")
        pEntry.val.fileSize <- 0

        pEntry.val.aMetadata <- @BSys::memAlloc(blob<Entry::Metadata::Fat>.size)
        pEntry.val.aMetadata.ptr<blob<Entry::Metadata::Fat>>.val.cluster <- 0
        pEntry.val.aMetadata.ptr<blob<Entry::Metadata::Fat>>.val.dirCluster <- 0
        pEntry.val.aMetadata.ptr<blob<Entry::Metadata::Fat>>.val.dirEntryOffset <- 0

        pEntry.val.filesystem <- {it.adr.ptr<blob<FilesystemFat>>}

        ret pEntry
    ;

