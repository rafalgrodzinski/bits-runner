    getEntry fun: path blob<@B::String> -> ptr<blob<Entry>>
        // path must start with a slash
        if path.string[0] != '/': ret {0}

        pCurrentEntry ptr<blob<Entry>> <- it.getRootEntry()
        path <- path.subStringFrom(1)

        // go through each path components until the end or if one cannot be found
        rep path.length() > 0 //and isNextEntryFound
            isNextEntryFound bool
            isLookingForDir bool
            separatorIndex u32 <- path.find(@B::StringForChar('/'))
            // if path components are still remaining, take name until the next slash /
            nextEntryName blob<@B::String>
            if separatorIndex > 0
                isLookingForDir <- true
                nextEntryName <- path.subStringTo(separatorIndex)
                path <- path.subStringFrom(separatorIndex + 1)
            // otherwise take the whole remaining path as the next entry name
            else
                nextEntryName <- path
                path <- @B::String("")
            ;

            isRoot bool <- pCurrentEntry.val.name.isEqual(@B::String("/"))
            aBuffer a
            entriesPerRead u32
            maxEntriesCount u32
            sector u32
            cluster u32
            isFinished bool

            // Root directory needs a separate logic as it doesn't use clusters
            if isRoot
                aBuffer <- @BSys::memAlloc(it.fatBytesPerSector)
                entriesPerRead <- it.fatBytesPerSector / FAT_BYTES_PER_ENTRY
                maxEntriesCount <- it.fatRootDirEntriesCount
                sector <- it.fatRootDirFirstSector
            // Sub directories use clusters
            else
                aBuffer <- @BSys::memAlloc(it.fatBytesPerSector * it.fatSectorsPerCluster)
                entriesPerRead <- (it.fatBytesPerSector * it.fatSectorsPerCluster) / FAT_BYTES_PER_ENTRY
                maxEntriesCount <- 65_536
                cluster <- pCurrentEntry.val.aMetadata.ptr<blob<Entry::Metadata::Fat>>.val.cluster
            ;

            rep dirEntryIndex u32, dirEntryIndex < maxEntriesCount and not isFinished, dirEntryIndex <- dirEntryIndex + entriesPerRead
                if isRoot
                    // Root dir is scanned sctor by sector
                    it.area.readSectors(sector, 1, aBuffer)
                    sector <- sector + 1
                else
                    // Sub dirs are scanned cluster by cluster
                    sector <- it.sectorForCluster(cluster)
                    it.area.readSectors(sector, it.fatSectorsPerCluster, aBuffer)
                    cluster <- it.nextCluster(cluster)
                ;

                // Iterate over buffered entries
                rep i u32, i < entriesPerRead and not isFinished, i <- i + 1
                    pFoundEntry ptr<blob<Entry>> <- it.entryForFatEntry(aBuffer + i * FAT_BYTES_PER_ENTRY)

                    if pFoundEntry.vadr = 0
                        isFinished <- true
                    else if pFoundEntry.val.kind = Entry::KIND_FILE or pFoundEntry.val.kind = Entry::KIND_DIRECTORY
                        if pFoundEntry.val.name.isEqual(nextEntryName)
                            isFinished <- true
                            // Make sure that only the last path component is a file
                            if not isLookingForDir or pFoundEntry.val.kind = Entry::KIND_DIRECTORY
                                pFoundEntry.val.aMetadata.ptr<blob<Entry::Metadata::Fat>>.val.dirCluster <- pCurrentEntry.val.aMetadata.ptr<blob<Entry::Metadata::Fat>>.val.cluster
                                pFoundEntry.val.aMetadata.ptr<blob<Entry::Metadata::Fat>>.val.dirEntryOffset <- (dirEntryIndex + i) * FAT_BYTES_PER_ENTRY

                                pCurrentEntry <- pFoundEntry
                                isNextEntryFound <- true
                            ;
                        ;
                    ;
                ;
            ;

            // required entry in the path not found
            if not isNextEntryFound
                @BSys::memFree(pCurrentEntry.vadr)
                ret {0}
            ;
        ;

        pCurrentEntry.val.filesystem <- {it.adr.ptr<blob<FilesystemFat>>}
        ret pCurrentEntry
    ;

