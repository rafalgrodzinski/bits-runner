@module DeviceVideo

@import Bus
@import BSys
@import Sched

// PCI
SVGA2_VENDOR_ID u16 <- 0x15ad
SVGA2_DEVICE_ID u16 <- 0x0405

// Port offsets
SVGA2_INDEX_PORT u16 <- 0x00
SVGA2_VALUE_PORT u16 <- 0x01

// Specification
SVGA2_SPECS_VER u32 <- 0x9000_0002

// Registers
SVGA2_REG_ID u16 <- 0x00
SVGA2_REG_ENABLE u16 <- 0x01

SVGA2_REG_WIDTH u16 <- 0x02
SVGA2_REG_HEIGHT u16 <- 0x03
SVGA2_REG_BPP u16 <- 0x07

SVGA2_REG_FB_START u16 <- 0x0d
SVGA2_REG_FB_OFFSET u16 <- 0x0e
SVGA2_REG_FB_SIZE u16 <- 0x10

SVGA2_REG_FIFO_START u16 <- 0x12
SVGA2_REG_FIFO_SIZE u16 <- 0x13

SVGA2_REG_CAPS u16 <- 0x11

@export Svga2 blob: DeviceVideo
    portBase u16
    width u32
    height u32
    pFrameBuffer ptr<data<u32>>

    readReg fun: reg u16 -> u32
        @BSys.out32(it.portBase + SVGA2_INDEX_PORT, reg)
        ret @BSys.in32(it.portBase + SVGA2_VALUE_PORT)
    ;

    writeReg fun: reg u16, value u32
        @BSys.out32(it.portBase + SVGA2_INDEX_PORT, reg)
        @BSys.out32(it.portBase + SVGA2_VALUE_PORT, value)
    ;

    init fun: devicePci blob<@Bus.DevicePci>
        // Check if device matches
        if devicePci.vendorId != SVGA2_VENDOR_ID or devicePci.deviceId != SVGA2_DEVICE_ID: ret

        // Enable bus master, memory space, and IO space
        devicePci.sendCommand(0b0111)

        // get base port for registers
        it.portBase <- (devicePci.bar0 - 1).u16

        // check version
        it.writeReg(SVGA2_REG_ID, SVGA2_SPECS_VER)
        if it.readReg(SVGA2_REG_ID) != SVGA2_SPECS_VER: ret

        fifoStart u32 <- it.readReg(SVGA2_REG_FIFO_START)
        fifoSize u32 <- it.readReg(SVGA2_REG_FIFO_SIZE)
        caps u32 <- it.readReg(SVGA2_REG_CAPS)

        /*
        it.setMode(1024, 768, 32)

        rep y u32, y < it.height, y <- y + 1
            rep x u32, x < it.width, x <- x + 1
                red u8 <- (255 - (x * 255) / it.width).u8
                green u8 <- ((x * 255) / it.width).u8
                blue u8 <- ((y * 255) / it.height).u8

                color u32 <- (red << 16) | (green << 8) | (blue)
                it.pFrameBuffer.val[y * it.width + x] <- color
            ;
        ;
        */
    ;

    // MARK: proto<DeviceVideo>

    getWidth fun -> u32
        ret it.width
    ;

    getHeight fun -> u32
        ret it.height
    ;

    setMode fun: resolution u32, bpp u32
        width u32 <- resolution >> 16
        height u32 <- resolution & 0xffff

        it.width <- width
        it.height <- height

        it.writeReg(SVGA2_REG_WIDTH, width)
        it.writeReg(SVGA2_REG_HEIGHT, height)
        it.writeReg(SVGA2_REG_BPP, bpp)
        it.writeReg(SVGA2_REG_ENABLE, 1)

        // map memory
        fbStart u32 <- it.readReg(SVGA2_REG_FB_START)
        fbOffset u32 <- it.readReg(SVGA2_REG_FB_OFFSET)
        fbSize u32 <- it.readReg(SVGA2_REG_FB_SIZE)
        it.pFrameBuffer <- {fbStart + fbOffset}
        @Sched.mapRawMemory(fbStart, fbSize)
    ;

    commitDrawing fun
    ;

    clear fun: color u32
        rep i u32, i < it.width * it.height, i <- i + 1
            it.pFrameBuffer.val[i] <- color
        ;
    ;

    drawPixel fun: x u32, y u32, color u32
        it.pFrameBuffer.val[y * it.width + x] <- color
    ;

    drawLine fun: x1 u32, y1 u32, x2 u32, y2 u32, color u32
        dx s32 <- if x2 >= x1: x2 - x1 else: x1 - x2
        dy s32 <- if y2 >= y1: y2 - y1 else: y1 - y2

        // more horizonal line
        if dx >= dy
            if x2 < x1
                tmpX u32 <- x1
                x1 <- x2
                x2 <- tmpX

                tmpY u32 <- y1
                y1 <- y2
                y2 <- tmpY
            ;

            p s32 <- dy * 2 - dx
            y u32 <- y1
            rep x u32 <- x1, x <= x2, x <- x + 1
                it.drawPixel(x, y, color)
                if p < 0
                    p <- p + 2 * dy
                else
                    y <- if y1 <= y2: y + 1 else: y - 1
                    p <- p + 2 * (dy - dx)
                ;
            ;
        // more vertical line
        else
            if y2 < y1
                tmpX u32 <- x1
                x1 <- x2
                x2 <- tmpX

                tmpY u32 <- y1
                y1 <- y2
                y2 <- tmpY
            ;

            p s32 <- dx * 2 - dy
            x u32 <- x1
            rep y u32 <- y1, y <= y2, y <- y + 1
                it.drawPixel(x, y, color)
                if p < 0
                    p <- p + 2 * dx
                else
                    x <- if x1 <= x2: x + 1 else: x - 1
                    p <- p + 2 * (dx - dy)
                ;
            ;
        ;
    ;
;