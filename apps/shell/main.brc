    // der
    @B::String("der").printColor(@B::String::FOREGROUND_BROWN | @B::String::ATTRIB_BRIGHT)
    @Syscall::Audio::play(330, 400)
    @Syscall::Process::sleep(450)

    // what
    @B::String(" what").printColor(@B::String::FOREGROUND_BROWN | @B::String::ATTRIB_BRIGHT)
    @Syscall::Audio::play(294, 400)
    @Syscall::Process::sleep(450)

    // you
    @B::String(" you").printColor(@B::String::FOREGROUND_BROWN | @B::String::ATTRIB_BRIGHT)
    @Syscall::Audio::play(294, 400)
    @Syscall::Process::sleep(450)

    // are
    @B::String(" are").printlnColor(@B::String::FOREGROUND_BROWN | @B::String::ATTRIB_BRIGHT)
    @Syscall::Audio::play(262, 800)
    @Syscall::Process::sleep(850)
;